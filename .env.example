# Struudel — environment variables.
# Copy to `.env` (project root) and fill in the blanks. Both the app and the
# bundled Postgres container read from this file.
#
# Settings are loaded by pydantic-settings (struudel/config.py); names are
# case-insensitive. Required fields are validated at startup and the app
# refuses to start with missing values.

# =============================================================================
# REQUIRED — the app refuses to start without these
# =============================================================================

# PostgreSQL connection. DSN is assembled as
# postgresql+psycopg://${DB_USER}:${DB_PASS}@${DB_HOST}/${DB_NAME}
# Same values are used to initialise the Postgres container (POSTGRES_USER /
# POSTGRES_PASSWORD / POSTGRES_DB) — pick strong values in production.
# Dev quickstart: DB_USER=struudel / DB_PASS=struudel works fine.
DB_USER=
DB_PASS=

# OpenID Connect provider. Point this at your IdP's discovery document and
# register a client there to obtain ID and secret.
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Bearer token for the SCIM v2 provisioning endpoint at /scim/v2. The IdP
# (or any SCIM-capable directory) must push users and groups to that endpoint
# using this token. Groups exist only via SCIM — there is no UI for them.
SCIM_TOKEN=

# =============================================================================
# STRONGLY RECOMMENDED FOR PRODUCTION
# =============================================================================

# Flask session signing key. The default in code is INSECURE — override here
# with a long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-change-for-production

# Public base URL of the deployed app. Used in outgoing mail (invitation
# links etc.) and OIDC redirect handling behind a reverse proxy.
APP_BASE_URL=https://struudel.example.com

# Mark the session cookie Secure (HTTPS-only). MUST be true behind a TLS
# terminator in production.
SESSION_COOKIE_SECURE=true

# =============================================================================
# Mail — SMTP for invitations, reminders, response notifications
# =============================================================================

# Disable outgoing mail entirely (jobs still queue but send_mail no-ops).
# Useful for staging environments.
# MAIL_ENABLED=true

MAIL_HOST=
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@struudel.example.com
MAIL_FROM_NAME=Struudel
# Pick one depending on the SMTP server's TLS support
MAIL_STARTTLS=true
# MAIL_SSL=true
# MAIL_TIMEOUT_SECONDS=10

# =============================================================================
# Optional — defaults are sensible
# =============================================================================
# DB_HOST=postgres
# DB_NAME=struudel
# OIDC_SCOPES=openid profile email
# Display name of the OIDC provider, shown on the login button
# ("Login with <name>") and the redirect spinner.
# OIDC_PROVIDER_NAME=SSO
# APP_TIMEZONE=Europe/Berlin
# POLL_RETENTION_DAYS=30
# SESSION_LIFETIME_HOURS=12
# SESSION_COOKIE_NAME=struudel
# SESSION_COOKIE_HTTPONLY=true
# SESSION_COOKIE_SAMESITE=Lax
# HUEY_REDIS_URL=redis://redis:6379/0
# SESSION_REDIS_URL=redis://redis:6379/1
# APP_STATE_REDIS_URL=redis://redis:6379/2
# HUEY_WORKERS=4
# GUNICORN_WORKERS=4
